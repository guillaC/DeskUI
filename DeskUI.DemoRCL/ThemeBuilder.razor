@using Microsoft.JSInterop
@inject IJSRuntime JS

<style>
    .preview-theme {
        @foreach (Var
                kv in cssVars)
        {
            @($"{kv.Key}: {kv.RawValue};")
        }
    }

    /* disposition */
    .du-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px 24px;
        margin-top: 12px;
    }

    .du-prop-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 6px 0;
        border-bottom: 1px solid #e0e0e0;
    }

    .du-prop-label {
        width: 180px;
        font-size: 13px;
        color: #444;
        user-select: none;
    }

    /* input */
    .du-prop-input {
        flex: 1;
        padding: 6px 10px;
        background: #fff;
        border: 1px solid #ccc;
        border-radius: 4px;
        color: #222;
        font-size: 13px;
        outline: none;
        transition: border-color 120ms ease;
    }

        .du-prop-input:hover {
            border-color: #999;
        }

        .du-prop-input:focus {
            border-color: #4da3ff;
        }

    /* badge input */
    .du-input-unit {
        position: relative;
        flex: 1; /* indispensable */
        display: flex; /* pour que l’input prenne toute la largeur */
    }

        .du-input-unit .du-prop-input {
            padding-right: 48px; /* espace pour le badge */
        }

    .du-unit {
        position: absolute;
        right: 6px;
        top: 50%;
        transform: translateY(-50%);
        background: #e5e5e5; /* gris clair visible */
        color: #444;
        font-size: 12px;
        padding: 2px 6px;
        border-radius: 4px;
        pointer-events: none;
        border: 1px solid #ccc;
        z-index: 2; /* pour être au-dessus de l’input */
    }
</style>

<h1>Theme Builder</h1>

<FloatingWindow Title="Preview"
                Theme="preview-theme"
                Id="@Guid.NewGuid()"
                AllowClose="true"
                Docked="true">
    <div>
        <p>Hello World !</p>
    </div>
</FloatingWindow>

<h2>CSS Variables</h2>

<div class="du-grid">
    @foreach (var v in cssVars)
    {
        <div class="du-prop-row">
            <label class="du-prop-label">@v.Key</label>
            @if (v.InputType == InputType.Number)
            {
                <div class="du-input-unit">
                    <input type="number"
                           class="du-prop-input"
                           value="@v.Number"
                           @oninput="e => UpdateVar(v.Key, e.Value?.ToString())" />
                    <span class="du-unit">@v.Unit</span>
                </div>
            }
            else
            {
                <input type="@v.InputType.ToString().ToLower()"
                       class="du-prop-input"
                       value="@v.RawValue"
                       @oninput="e => UpdateVar(v.Key, e.Value?.ToString())" />
            }
        </div>
    }
</div>
